---
const simpleIcon = (name: string, color = "90A1B9") =>
  `https://cdn.simpleicons.org/${name}/${color}`;

const socialLinks = [
  {
    label: "YouTube",
    icon: simpleIcon("youtube", "FF0000"),
  },
  {
    label: "Instagram",
    icon: simpleIcon("instagram", "E4405F"),
  },
  {
    label: "TikTok",
    href: "https://www.tiktok.com/@ddedenil?_t=ZM-8yNyhwoZnaq&_r=1",
    icon: simpleIcon("tiktok", "F8FAFC"),
  },
  {
    label: "GitHub",
    href: "https://github.com/DenilDenilson",
    icon: simpleIcon("github", "F8FAFC"),
  },
];

const cvPath = "/Denilson-Trujillo_CV-es.pdf";
---

<footer
  class="outline-theme-stroke flex min-h-14 items-stretch justify-between outline"
>
  <div class="flex min-w-0 items-stretch">
    <p
      class="text-theme-foreground flex items-center px-5 text-sm sm:w-40 sm:px-6"
    >
      find me in:
    </p>
    <ul class="flex items-stretch">
      {
        socialLinks.map((social) => (
          <li class="border-theme-stroke border-l">
            {social.href ? (
              <a
                href={social.href}
                target="_blank"
                rel="noreferrer"
                aria-label={social.label}
                title={social.label}
                class="group grid h-full w-12 place-items-center transition hover:bg-slate-950 sm:w-14"
              >
                <img
                  src={social.icon}
                  alt=""
                  loading="lazy"
                  class="h-5 w-5 opacity-70 transition group-hover:scale-110 group-hover:opacity-100"
                />
              </a>
            ) : (
              <span
                aria-label={`${social.label} sin enlace configurado`}
                title={`${social.label} sin enlace configurado`}
                class="grid h-full w-12 cursor-default place-items-center opacity-45 sm:w-14"
              >
                <img
                  src={social.icon}
                  alt=""
                  loading="lazy"
                  class="h-5 w-5"
                />
              </span>
            )}
          </li>
        ))
      }
    </ul>
  </div>

  <a
    href={cvPath}
    download
    class="border-theme-stroke group ml-auto flex items-center gap-2 border-l px-4 text-sm font-medium text-slate-50 transition hover:bg-slate-950 hover:text-primary-background sm:px-6"
  >
    <span class="hidden sm:inline">descargar-cv</span>
    <span class="sm:hidden">cv</span>
    <svg
      class="h-5 w-5 text-theme-foreground transition group-hover:text-primary-background"
      viewBox="0 0 24 24"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path
        d="M12 3v10m0 0 4-4m-4 4-4-4M5 16v3h14v-3"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>
</footer>
