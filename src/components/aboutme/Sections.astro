---
import ProjectCard from "../projects/ProjectCard.astro";
---

<section-ext>
  <li
    class="flex h-12 cursor-pointer items-center gap-3 bg-slate-700 px-6 py-3"
  >
    <svg
      class="transition-transform duration-200"
      width="5"
      height="8"
      viewBox="0 0 5 8"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M4.66699 4L0.666992 8L0.666992 0L4.66699 4Z" fill="#F8FAFC"
      ></path>
    </svg>
    <span class="text-slate-50"> Actualmente desarrollando </span>
  </li>
  <div class="info max-h-0 overflow-hidden transition-all duration-300">
    <div class="p-6">
      <ProjectCard />
    </div>
  </div>
</section-ext>

<section-ext>
  <li
    class="flex h-12 cursor-pointer items-center gap-3 bg-slate-700 px-6 py-3"
  >
    <svg
      class="transition-transform duration-200"
      width="5"
      height="8"
      viewBox="0 0 5 8"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M4.66699 4L0.666992 8L0.666992 0L4.66699 4Z" fill="#F8FAFC"
      ></path>
    </svg>
    <span class="text-slate-50"> Actualmente estudiando </span>
  </li>
  <div class="info max-h-0 overflow-hidden transition-all duration-300">
    <div class="p-6">
      <li class="flex items-baseline gap-2">
        <svg
          class="h-8 w-8"
          xmlns="http://www.w3.org/2000/svg"
          preserveAspectRatio="xMidYMid"
          viewBox="0 0 256 346"
          ><path
            d="M83 267s-14 8 9 11c27 3 41 2 71-3 0 0 8 5 19 9-67 29-153-2-99-17M74 230s-15 11 8 13c29 3 52 3 92-4 0 0 6 5 15 8-82 24-173 2-115-17"
            fill="#5382A1"></path><path
            d="M144 166c17 19-4 36-4 36s42-22 22-49c-18-26-32-38 44-82 0 0-119 29-62 95"
            fill="#E76F00"></path><path
            d="M233 295s10 8-10 15c-39 12-163 15-197 0-12-5 11-13 18-14l12-2c-14-9-89 19-38 28 138 22 251-10 215-27M89 190s-63 15-22 21c17 2 51 2 83-1 26-2 52-7 52-7l-16 9c-64 16-187 8-151-9 30-14 54-13 54-13M202 253c64-33 34-66 13-61l-7 2s2-3 6-5c41-14 73 43-14 66l2-2"
            fill="#5382A1"></path><path
            d="M162 0s36 36-34 91c-56 45-12 70 0 99-32-30-56-56-40-80 23-35 89-53 74-110"
            fill="#E76F00"></path><path
            d="M95 345c62 4 158-3 160-32 0 0-4 11-51 20-53 10-119 9-158 2 0 0 8 7 49 10"
            fill="#5382A1"></path></svg
        >
        <label for="webFilter" class="ml-3 text-white">Java</label>
      </li>
    </div>
  </div>
</section-ext>

<script>
  class SectionExt extends HTMLElement {
    connectedCallback() {
      const liArea = this.querySelector("li");
      const liIcon = this.querySelector("svg");
      const info = this.querySelector(".info");

      liArea?.addEventListener("click", () => {
        liIcon?.classList.toggle("rotate-90");
        info?.classList.toggle("max-h-0");
        info?.classList.toggle("max-h-[800px]");
      });
    }
  }

  customElements.define("section-ext", SectionExt);
</script>
