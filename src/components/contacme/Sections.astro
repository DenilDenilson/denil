---
const simpleIcon = (name: string, color = "90A1B9") =>
  `https://cdn.simpleicons.org/${name}/${color}`;

const contactItems = [
  {
    label: "denildenilson@gmail.com",
    href: "mailto:denildenilson@gmail.com",
    icon: simpleIcon("gmail", "EA4335"),
  },
  {
    label: "jdtrujillos@uni.pe",
    href: "mailto:jdtrujillos@uni.pe",
    icon: simpleIcon("microsoftoutlook", "0078D4"),
  },
  {
    label: "+51 933 156 539",
    href: "https://wa.me/51933156539",
    icon: simpleIcon("whatsapp", "25D366"),
  },
];

const socialLinks = [
  { label: "YouTube", icon: simpleIcon("youtube", "FF0000") },
  { label: "Instagram", icon: simpleIcon("instagram", "E4405F") },
  {
    label: "TikTok",
    href: "https://www.tiktok.com/@ddedenil?_t=ZM-8yNyhwoZnaq&_r=1",
    icon: simpleIcon("tiktok", "F8FAFC"),
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/denilson-trujillo-4127692ba/",
    icon: simpleIcon("linkedin", "0A66C2"),
  },
  {
    label: "GitHub",
    href: "https://github.com/DenilDenilson",
    icon: simpleIcon("github", "F8FAFC"),
  },
];
---

<section-ext class="xl:hidden">
  <li class="flex h-12 cursor-pointer items-center gap-3 bg-slate-700 px-6 py-3">
    <svg
      class="transition-transform duration-200"
      width="5"
      height="8"
      viewBox="0 0 5 8"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M4.66699 4L0.666992 8L0.666992 0L4.66699 4Z" fill="#F8FAFC"
      ></path>
    </svg>
    <span class="text-slate-50">Contáctame</span>
  </li>
  <div class="info max-h-0 overflow-hidden transition-all duration-300">
    <ul class="flex flex-col gap-1 py-3">
      {
        contactItems.map((item) => (
          <li>
            <a
              href={item.href}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noreferrer" : undefined}
              class="flex items-center gap-3 px-6 py-2"
            >
              <img src={item.icon} alt="" loading="lazy" class="h-4 w-4" />
              <span class="truncate">{item.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section-ext>

<section-ext class="xl:hidden">
  <li class="flex h-12 cursor-pointer items-center gap-3 bg-slate-700 px-6 py-3">
    <svg
      class="transition-transform duration-200"
      width="5"
      height="8"
      viewBox="0 0 5 8"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M4.66699 4L0.666992 8L0.666992 0L4.66699 4Z" fill="#F8FAFC"
      ></path>
    </svg>
    <span class="text-slate-50">Encuéntrame también en:</span>
  </li>
  <div class="info max-h-0 overflow-hidden transition-all duration-300">
    <ul class="flex flex-col gap-1 py-3">
      {
        socialLinks.map((social) => (
          <li>
            {social.href ? (
              <a
                href={social.href}
                target="_blank"
                rel="noreferrer"
                class="flex items-center gap-3 px-6 py-2"
              >
                <img src={social.icon} alt="" loading="lazy" class="h-4 w-4" />
                <span>{social.label}</span>
              </a>
            ) : (
              <span class="flex items-center gap-3 px-6 py-2 text-slate-500">
                <img
                  src={social.icon}
                  alt=""
                  loading="lazy"
                  class="h-4 w-4 opacity-70"
                />
                <span>{social.label}</span>
              </span>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section-ext>

<script>
  if (!customElements.get("section-ext")) {
    class SectionExt extends HTMLElement {
      connectedCallback() {
        const liArea = this.querySelector("li");
        const liIcon = this.querySelector("svg");
        const info = this.querySelector(".info");

        liArea?.addEventListener("click", () => {
          liIcon?.classList.toggle("rotate-90");
          info?.classList.toggle("max-h-0");
          info?.classList.toggle("max-h-[800px]");
        });
      }
    }

    customElements.define("section-ext", SectionExt);
  }
</script>
