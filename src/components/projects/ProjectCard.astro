---
const fallbackProject = {
  title: "mmj-web",
  description: "Web oficial de MMJ Smart Electronics.",
  stack: ["Astro", "TypeScript", "JavaScript"],
  categories: ["web"],
  codeUrl: "https://github.com/DenilDenilson/mmj-web",
  previewUrl: "https://www.smartelectronics.com.pe/",
  image: "https://opengraph.githubassets.com/1/DenilDenilson/mmj-web",
};

const { project = fallbackProject } = Astro.props;
---

<section
  data-project-card
  data-project-id={project.title}
  data-categories={project.categories.join(" ")}
  class="border-theme-stroke w-full overflow-hidden rounded-lg border bg-slate-950 xl:grid xl:grid-cols-[260px_1fr]"
>
  <div
    class="border-theme-stroke aspect-[2/1] w-full overflow-hidden border-b bg-slate-950 xl:h-full xl:min-h-56 xl:border-r xl:border-b-0"
  >
    <img
      src={project.image}
      alt={`Vista previa de ${project.title}`}
      class="h-full w-full object-cover"
    />
  </div>
  <div class="flex flex-col justify-between p-5 xl:p-6">
    <div>
      <h2
        class="text-heading-foreground mb-3 text-2xl font-semibold xl:text-3xl"
      >
        {project.title}
      </h2>
      <ul class="mb-2 flex flex-row flex-wrap gap-2">
        {
          project.stack.map((technology) => (
            <li>
              <span class="bg-theme-backdrop border-theme-stroke flex rounded-md border px-2 py-1 text-xs text-slate-50">
                {technology}
              </span>
            </li>
          ))
        }
      </ul>
      <div class="mt-4 text-sm leading-relaxed text-gray-400">
        {project.description}
      </div>
    </div>
    <footer class="mt-4 flex items-end justify-start gap-x-4">
      <a
        target="_blank"
        rel="noreferrer"
        href={project.codeUrl}
        role="link"
        class="text-md group inline-flex max-w-fit items-center justify-center gap-2 rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-base text-white transition hover:border-gray-300 hover:bg-gray-100 hover:text-gray-800 focus:outline-none focus-visible:ring focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:outline-none active:bg-white"
      >
        <svg
          class="size-6"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
            d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"
          ></path></svg
        >
        Código
      </a>
      {
        project.previewUrl && (
          <a
            target="_blank"
            rel="noreferrer"
            href={project.previewUrl}
            role="link"
            class="text-md group inline-flex max-w-fit items-center justify-center gap-2 rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-base text-white transition hover:border-gray-300 hover:bg-gray-100 hover:text-gray-800 focus:outline-none focus-visible:ring focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:outline-none active:bg-white"
          >
            <svg
              class="size-4"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
            Demo
          </a>
        )
      }
    </footer>
  </div>
</section>
