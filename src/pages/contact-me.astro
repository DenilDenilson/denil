---
import Sections from "../components/contacme/Sections.astro";
import Layout from "../layouts/Layout.astro";

const simpleIcon = (name: string, color = "90A1B9") =>
  `https://cdn.simpleicons.org/${name}/${color}`;

const contactItems = [
  {
    label: "denildenilson@gmail.com",
    href: "mailto:denildenilson@gmail.com",
    icon: simpleIcon("gmail", "EA4335"),
  },
  {
    label: "jdtrujillos@uni.pe",
    href: "mailto:jdtrujillos@uni.pe",
    icon: simpleIcon("microsoftoutlook", "0078D4"),
  },
  {
    label: "+51 933 156 539",
    href: "https://wa.me/51933156539",
    icon: simpleIcon("whatsapp", "25D366"),
  },
];

const socialLinks = [
  {
    label: "YouTube",
    icon: simpleIcon("youtube", "FF0000"),
  },
  {
    label: "Instagram",
    icon: simpleIcon("instagram", "E4405F"),
  },
  {
    label: "TikTok",
    href: "https://www.tiktok.com/@ddedenil?_t=ZM-8yNyhwoZnaq&_r=1",
    icon: simpleIcon("tiktok", "F8FAFC"),
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/denilson-trujillo-4127692ba/",
    icon: simpleIcon("linkedin", "0A66C2"),
  },
  {
    label: "GitHub",
    href: "https://github.com/DenilDenilson",
    icon: simpleIcon("github", "F8FAFC"),
  },
];
---

<Layout>
  <main
    class="mt-14 mb-14 flex h-[calc(100vh-7rem)] flex-col overflow-y-auto xl:flex-row xl:overflow-hidden"
  >
    <ul class="flex flex-col gap-1 xl:hidden">
      <p class="text-heading-foreground p-6 text-sm">_contact-me</p>
    </ul>
    <Sections />

    <section class="px-6 pb-10 xl:hidden">
      <form class="mx-auto max-w-md space-y-5">
        <label class="block">
          <span class="mb-2 block text-sm">_name:</span>
          <input
            type="text"
            class="bg-theme-backdrop border-theme-stroke focus:border-primary-background h-12 w-full rounded-lg border px-4 text-slate-50 outline-none transition"
          />
        </label>
        <label class="block">
          <span class="mb-2 block text-sm">_email:</span>
          <input
            type="email"
            class="bg-theme-backdrop border-theme-stroke focus:border-primary-background h-12 w-full rounded-lg border px-4 text-slate-50 outline-none transition"
          />
        </label>
        <label class="block">
          <span class="mb-2 block text-sm">_message:</span>
          <textarea
            placeholder="Escribe tu mensaje aquí..."
            class="bg-theme-backdrop border-theme-stroke focus:border-primary-background h-44 w-full resize-none rounded-lg border px-4 py-3 text-slate-50 outline-none transition placeholder:text-slate-700"></textarea>
        </label>
        <button
          type="submit"
          class="bg-primary-background text-primary-inverted h-11 rounded-lg px-5 text-sm font-semibold transition hover:brightness-110"
        >
          enviar-mensaje
        </button>
      </form>
    </section>

    <section
      class="outline-theme-stroke hidden h-full w-72 overflow-y-auto outline xl:block"
    >
      <ul
        class="outline-theme-stroke flex items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <span class="h-3 w-3 rounded-sm bg-teal-400"></span>
        <span>Contacto</span>
      </ul>
      <ul class="flex flex-col gap-1 py-3">
        {
          contactItems.map((item) => (
            <li>
              <a
                href={item.href}
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noreferrer" : undefined}
                class="group flex items-center gap-3 px-6 py-2 transition hover:bg-slate-950 hover:text-slate-50"
              >
                <img
                  src={item.icon}
                  alt=""
                  loading="lazy"
                  class="h-4 w-4 shrink-0 opacity-80 transition group-hover:opacity-100"
                />
                <span class="truncate">{item.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <ul
        class="outline-theme-stroke flex items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <span class="h-3 w-3 rounded-sm bg-rose-400"></span>
        <span>Encuéntrame también</span>
      </ul>
      <ul class="flex flex-col gap-1 py-3">
        {
          socialLinks.map((social) => (
            <li>
              {social.href ? (
                <a
                  href={social.href}
                  target="_blank"
                  rel="noreferrer"
                  class="group flex items-center gap-3 px-6 py-2 transition hover:bg-slate-950 hover:text-slate-50"
                >
                  <img
                    src={social.icon}
                    alt=""
                    loading="lazy"
                    class="h-4 w-4 shrink-0 opacity-80 transition group-hover:opacity-100"
                  />
                  <span>{social.label}</span>
                </a>
              ) : (
                <span class="flex items-center gap-3 px-6 py-2 text-slate-500">
                  <img
                    src={social.icon}
                    alt=""
                    loading="lazy"
                    class="h-4 w-4 shrink-0 opacity-60"
                  />
                  <span>{social.label}</span>
                </span>
              )}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="hidden flex-1 flex-col xl:flex">
      <ul class="flex h-12 gap-0"></ul>
      <div
        class="outline-theme-stroke grid flex-1 place-content-center overflow-y-auto px-8 py-8 outline"
      >
        <form class="w-[min(100%,410px)] space-y-7">
          <label class="block">
            <span class="mb-2 block text-sm">_name:</span>
            <input
              type="text"
              class="bg-theme-backdrop border-theme-stroke focus:border-primary-background h-12 w-full rounded-lg border px-4 text-slate-50 outline-none transition"
            />
          </label>
          <label class="block">
            <span class="mb-2 block text-sm">_email:</span>
            <input
              type="email"
              class="bg-theme-backdrop border-theme-stroke focus:border-primary-background h-12 w-full rounded-lg border px-4 text-slate-50 outline-none transition"
            />
          </label>
          <label class="block">
            <span class="mb-2 block text-sm">_message:</span>
            <textarea
              placeholder="Escribe tu mensaje aquí..."
              class="bg-theme-backdrop border-theme-stroke focus:border-primary-background h-48 w-full resize-none rounded-lg border px-4 py-3 text-slate-50 outline-none transition placeholder:text-slate-700"></textarea>
          </label>
          <button
            type="submit"
            class="bg-primary-background text-primary-inverted h-10 rounded-lg px-5 text-sm font-semibold transition hover:brightness-110"
          >
            enviar-mensaje
          </button>
        </form>
      </div>
    </section>

    <section class="hidden flex-1 flex-col xl:flex">
      <ul class="flex h-12 gap-0"></ul>
      <div
        class="outline-theme-stroke flex-1 overflow-auto px-8 py-5 leading-loose outline"
      >
        <pre class="text-sm leading-8"><code><span class="text-slate-500"> 1</span>  <span class="text-purple-400">const</span> <span class="text-indigo-500">button</span> = <span class="text-indigo-500">document</span>.<span class="text-indigo-500">querySelector</span>(<span class="text-orange-300">'#sendBtn'</span>);
<span class="text-slate-500"> 2</span>
<span class="text-slate-500"> 3</span>  <span class="text-purple-400">const</span> <span class="text-indigo-500">message</span> = &#123;
<span class="text-slate-500"> 4</span>    <span class="text-indigo-500">name</span>: <span class="text-orange-300">'NAME'</span>,
<span class="text-slate-500"> 5</span>    <span class="text-indigo-500">email</span>: <span class="text-orange-300">'email'</span>,
<span class="text-slate-500"> 6</span>    <span class="text-indigo-500">message</span>: <span class="text-orange-300">'message'</span>,
<span class="text-slate-500"> 7</span>    <span class="text-indigo-500">date</span>: <span class="text-orange-300">'date'</span>,
<span class="text-slate-500"> 8</span>  &#125;
<span class="text-slate-500"> 9</span>
<span class="text-slate-500">10</span>  <span class="text-indigo-500">button</span>.<span class="text-indigo-500">addEventListener</span>(<span class="text-orange-300">'click'</span>, () =&gt; &#123;
<span class="text-slate-500">11</span>    <span class="text-indigo-500">form</span>.<span class="text-indigo-500">send</span>(<span class="text-indigo-500">message</span>);
<span class="text-slate-500">12</span>  &#125;)</code></pre>
      </div>
    </section>
  </main>
</Layout>
