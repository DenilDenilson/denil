---
import Sections from "../components/contacme/Sections.astro";
import Layout from "../layouts/Layout.astro";

const simpleIcon = (name: string, color = "90A1B9") =>
  `https://cdn.simpleicons.org/${name}/${color}`;

const contactItems = [
  {
    label: "jordanpreseleccion@gmail.com",
    href: "mailto:jordanpreseleccion@gmail.com",
    icon: simpleIcon("gmail", "EA4335"),
  },
  {
    label: "jdtrujillos@uni.pe",
    href: "mailto:jdtrujillos@uni.pe",
    icon: simpleIcon("microsoftoutlook", "0078D4"),
  },
  {
    label: "+51 933 156 539",
    href: "https://wa.me/51933156539",
    icon: simpleIcon("whatsapp", "25D366"),
  },
];

const socialLinks = [
  {
    label: "YouTube",
    icon: simpleIcon("youtube", "FF0000"),
  },
  {
    label: "Instagram",
    icon: simpleIcon("instagram", "E4405F"),
  },
  {
    label: "TikTok",
    href: "https://www.tiktok.com/@ddedenil?_t=ZM-8yNyhwoZnaq&_r=1",
    icon: simpleIcon("tiktok", "F8FAFC"),
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/denilson-trujillo-4127692ba/",
    icon: "/icons/linkedin.svg",
  },
  {
    label: "GitHub",
    href: "https://github.com/DenilDenilson",
    icon: simpleIcon("github", "F8FAFC"),
  },
];

const serviceAreas = [
  "Backend y APIs",
  "Automatización de procesos",
  "Herramientas internas",
  "Software conectado a sensores/equipos",
  "IA aplicada a flujos reales",
];

const primaryActions = [
  {
    label: "email",
    href: "mailto:jordanpreseleccion@gmail.com",
    icon: simpleIcon("gmail", "EA4335"),
  },
  {
    label: "linkedin",
    href: "https://www.linkedin.com/in/denilson-trujillo-4127692ba/",
    icon: "/icons/linkedin.svg",
  },
  {
    label: "github",
    href: "https://github.com/DenilDenilson",
    icon: simpleIcon("github", "F8FAFC"),
  },
  {
    label: "whatsapp",
    href: "https://wa.me/51933156539",
    icon: simpleIcon("whatsapp", "25D366"),
  },
];
---

<Layout>
  <main
    class="mt-14 mb-14 flex h-[calc(100vh-7rem)] flex-col overflow-y-auto xl:flex-row xl:overflow-hidden"
  >
    <ul class="flex flex-col gap-1 xl:hidden">
      <p class="text-heading-foreground p-6 text-sm">_contact-me</p>
    </ul>
    <Sections />

    <section class="px-6 pb-10 xl:hidden">
      <div class="mx-auto max-w-md space-y-6">
        <div>
          <p class="mb-2 text-sm text-orange-300">disponible_para</p>
          <h1 class="text-heading-foreground text-2xl font-semibold">
            Hablemos si necesitas construir software útil.
          </h1>
        </div>
        <ul class="space-y-3">
          {
            serviceAreas.map((area) => (
              <li class="border-theme-stroke bg-theme-backdrop/50 rounded-lg border px-4 py-3 text-sm text-slate-50">
                {area}
              </li>
            ))
          }
        </ul>
        <div class="flex flex-wrap gap-3">
          {
            primaryActions.map((action) => (
              <a
                href={action.href}
                target={action.href.startsWith("http") ? "_blank" : undefined}
                rel={action.href.startsWith("http") ? "noreferrer" : undefined}
                class="border-theme-stroke bg-theme-backdrop flex items-center gap-2 rounded-lg border px-4 py-3 text-sm font-semibold text-slate-50 transition hover:border-primary-background hover:text-primary-background"
              >
                <img src={action.icon} alt="" loading="lazy" class="h-4 w-4" />
                {action.label}
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section
      class="outline-theme-stroke hidden h-full w-72 overflow-y-auto outline xl:block"
    >
      <ul
        class="outline-theme-stroke flex items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <span class="h-3 w-3 rounded-sm bg-teal-400"></span>
        <span>Contacto</span>
      </ul>
      <ul class="flex flex-col gap-1 py-3">
        {
          contactItems.map((item) => (
            <li>
              <a
                href={item.href}
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noreferrer" : undefined}
                class="group flex items-center gap-3 px-6 py-2 transition hover:bg-slate-950 hover:text-slate-50"
              >
                <img
                  src={item.icon}
                  alt=""
                  loading="lazy"
                  class="h-4 w-4 shrink-0 opacity-80 transition group-hover:opacity-100"
                />
                <span class="truncate">{item.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <ul
        class="outline-theme-stroke flex items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <span class="h-3 w-3 rounded-sm bg-rose-400"></span>
        <span>Encuéntrame también</span>
      </ul>
      <ul class="flex flex-col gap-1 py-3">
        {
          socialLinks.map((social) => (
            <li>
              {social.href ? (
                <a
                  href={social.href}
                  target="_blank"
                  rel="noreferrer"
                  class="group flex items-center gap-3 px-6 py-2 transition hover:bg-slate-950 hover:text-slate-50"
                >
                  <img
                    src={social.icon}
                    alt=""
                    loading="lazy"
                    class="h-4 w-4 shrink-0 opacity-80 transition group-hover:opacity-100"
                  />
                  <span>{social.label}</span>
                </a>
              ) : (
                <span class="flex items-center gap-3 px-6 py-2 text-slate-500">
                  <img
                    src={social.icon}
                    alt=""
                    loading="lazy"
                    class="h-4 w-4 shrink-0 opacity-60"
                  />
                  <span>{social.label}</span>
                </span>
              )}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="hidden flex-1 flex-col xl:flex">
      <ul class="flex h-12 gap-0"></ul>
      <div
        class="outline-theme-stroke grid flex-1 place-content-center overflow-y-auto px-8 py-8 outline"
      >
        <div class="w-[min(100%,520px)] space-y-8">
          <div>
            <p class="mb-3 text-sm text-orange-300">disponible_para</p>
            <h1 class="text-heading-foreground mb-5 text-3xl font-semibold leading-tight">
              Hablemos si necesitas construir software útil.
            </h1>
            <p class="leading-relaxed">
              Busco oportunidades full-time donde pueda aportar en backend,
              automatización, herramientas internas, sistemas conectados a
              hardware e IA aplicada a procesos reales.
            </p>
          </div>

          <ul class="grid gap-3">
            {
              serviceAreas.map((area) => (
                <li class="border-theme-stroke bg-theme-backdrop/50 rounded-lg border px-4 py-3 text-sm text-slate-50 transition hover:border-primary-background">
                  {area}
                </li>
              ))
            }
          </ul>

          <div class="flex flex-wrap gap-3">
            {
              primaryActions.map((action) => (
                <a
                  href={action.href}
                  target={action.href.startsWith("http") ? "_blank" : undefined}
                  rel={action.href.startsWith("http") ? "noreferrer" : undefined}
                  class="border-theme-stroke bg-theme-backdrop flex items-center gap-2 rounded-lg border px-4 py-3 text-sm font-semibold text-slate-50 transition hover:border-primary-background hover:text-primary-background"
                >
                  <img
                    src={action.icon}
                    alt=""
                    loading="lazy"
                    class="h-4 w-4"
                  />
                  {action.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="hidden flex-1 flex-col xl:flex">
      <ul class="flex h-12 gap-0"></ul>
      <div
        class="outline-theme-stroke flex-1 overflow-auto px-8 py-5 leading-loose outline"
      >
        <pre class="text-sm leading-8"><code><span class="text-slate-500"> 1</span>  <span class="text-purple-400">const</span> <span class="text-indigo-500">contact</span> = &#123;
<span class="text-slate-500"> 2</span>
<span class="text-slate-500"> 3</span>    <span class="text-indigo-500">email</span>: <span class="text-orange-300">'jordanpreseleccion@gmail.com'</span>,
<span class="text-slate-500"> 4</span>    <span class="text-indigo-500">altEmail</span>: <span class="text-orange-300">'jdtrujillos@uni.pe'</span>,
<span class="text-slate-500"> 5</span>    <span class="text-indigo-500">location</span>: <span class="text-orange-300">'Lima, Peru'</span>,
<span class="text-slate-500"> 6</span>    <span class="text-indigo-500">availability</span>: <span class="text-orange-300">'full-time'</span>,
<span class="text-slate-500"> 7</span>    <span class="text-indigo-500">roles</span>: [
<span class="text-slate-500"> 8</span>      <span class="text-orange-300">'backend'</span>,
<span class="text-slate-500"> 9</span>      <span class="text-orange-300">'systems'</span>,
<span class="text-slate-500">10</span>      <span class="text-orange-300">'automation'</span>,
<span class="text-slate-500">11</span>    ],
<span class="text-slate-500">12</span>    <span class="text-indigo-500">links</span>: &#123;
<span class="text-slate-500">13</span>      <span class="text-indigo-500">github</span>: <span class="text-orange-300">'github.com/DenilDenilson'</span>,
<span class="text-slate-500">14</span>      <span class="text-indigo-500">linkedin</span>: <span class="text-orange-300">'linkedin.com/in/denilson-trujillo-4127692ba'</span>,
<span class="text-slate-500">15</span>    &#125;,
<span class="text-slate-500">16</span>  &#125;;</code></pre>
      </div>
    </section>
  </main>
</Layout>
