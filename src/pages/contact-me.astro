        </li>
      </div>
    </section>
    <section class="hidden flex-1 flex-col xl:flex">
      <ul class="flex h-12 gap-0"></ul>
      <div
        class="outline-theme-stroke grid flex-1 place-content-center px-8 py-3 leading-loose outline"
      >
        <div class="p-6">
          <label for="nameContact" class="mb-2 block">_name:</label>
          <input
            type="text"
            id="nameContact"
            class="input bg-theme-backdrop border-theme-stroke input-bordered mb-6 h-12 w-full rounded-lg border-2 px-3 py-1"
          />
          <label for="emailContact" class="mb-2 block">_email:</label>
          <input
            type="email"
            id="emailContact"
            class="input bg-theme-backdrop border-theme-stroke input-bordered mb-6 h-12 w-full rounded-lg border-2 px-3 py-1"
          />
          <label for="messageContact" class="mb-2 block">_message:</label>
          <input
            type="text"
            id="messageContact"
            placeholder="Escribe tu mensaje aquí..."
            class="input bg-theme-backdrop border-theme-stroke input-bordered mb-6 h-48 w-full rounded-lg border-2 px-3 py-1"
          />
          <button
            type="submit"
            class="h-10 w-36 rounded-lg bg-slate-500 text-center text-sm font-semibold text-slate-700"
            >emviar-mensaje</button
          >
        </div>
      </div>
    </section>
    <!-- <section class="hidden flex-1 xl:block">
      <ul>Actual trabajo</ul>
      <li>TARJETA DEL TRABAJO ACTUAL</li>
    </section> -->
    <section class="hidden flex-1 flex-col xl:flex">
      <ul class="flex h-12 gap-0"></ul>
      <div class="outline-theme-stroke flex-1 px-8 py-3 leading-loose outline">
        <div>
          <span class="mr-4 inline-block w-4 text-right">1</span><span
            class="text-purple-400">const &#32;</span
          ><span class="text-indigo-500">button</span> = <span
            class="text-indigo-500">document</span
          >. <span class="text-indigo-500">querySelector</span>(<span
            class="text-orange-300">'#sendBtn'</span
          >);
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">2</span>
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">3</span><span
            class="text-purple-400">const &#32;</span
          ><span class="text-indigo-500">message</span> = <span>&#123;</span>
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">4</span><span
            class="text-indigo-500">name:</span
          ><span class="text-orange-300">"NAME"</span>,
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">5</span><span
            class="text-indigo-500">email:</span
          ><span class="text-orange-300">"email"</span>,
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">6</span><span
            class="text-indigo-500">message:</span
          ><span class="text-orange-300">"message"</span>,
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">7</span><span
            class="text-indigo-500">date:</span
          ><span class="text-orange-300">"date"</span>,
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">8</span><span
            >&#125;</span
          >
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">9</span>
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">10</span>
          <span class="text-indigo-500">button</span>.<span
            class="text-indigo-500">addEventListener</span
          >(<span class="text-orange-300">'click'</span>, () =&#62; &#123;
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">11</span>
          <span class="text-indigo-500">form</span>.<span
            class="text-indigo-500">send</span
          >(<span class="text-indigo-500">message</span>);
        </div>
        <div>
          <span class="mr-4 inline-block w-4 text-right">12</span>
          &#125;)
        </div>
      </div>
    </section>
  </main>
</Layout>
