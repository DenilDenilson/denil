      <h3 class="text-heading-foreground text-2xl">¡Gracias! 🤞</h3>
      <p class="text-center leading-relaxed">
        Tu mensaje ha sido enviado, recibirá una respuesta pronto
      </p>
      <button
        type="submit"
        class="bg-primary-background text-primary-inverted mt-6 h-12 w-48 rounded-lg text-center text-sm font-semibold"
        >emviar-nuevo-mensaje</button
      >
    </div>

    <section class="outline-theme-stroke hidden w-72 outline xl:block">
