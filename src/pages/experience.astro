---
import Sections from "../components/experience/Sections.astro";
import Layout from "../layouts/Layout.astro";

const experiences = [
  {
    company: "Laboratorios Dmedida S.A.C",
    role: "Desarrollador / Ingeniero de Automatización",
    period: "Ago 2025 – Abr 2026",
    description:
      "Automatización de reportes, integración de IA mediante Claude/MCP, lectura de sensores vía Modbus, comunicación MQTT y desarrollo de plataformas web para visualización de datos. También participé en ingeniería inversa de equipos de laboratorio usando Python, LabVIEW, osciloscopio y analizador lógico.",
    areas: ["Automatización", "Backend", "IoT", "IA aplicada"],
    stack: [
      "Python",
      "LabVIEW",
      "Modbus",
      "MQTT",
      "ESP32",
      "Linux",
      "Claude",
      "MCP",
    ],
  },
  {
    company: "MMJ Smart Electronics S.A.C",
    role: "Desarrollador Full Stack",
    period: "Ago 2023 – Jul 2025",
    description:
      "Desarrollo de plataformas web para monitoreo y control de equipos físicos mediante MQTT, firmware en Arduino y frontends desplegados en Vercel. Lideré la creación de un CRM interno con Next.js, Express y PostgreSQL para gestión comercial y visualización de ventas en tiempo real.",
    areas: ["Full stack", "Backend", "Herramientas internas", "IoT"],
    stack: [
      "Next.js",
      "Astro",
      "Express",
      "PostgreSQL",
      "MQTT",
      "Arduino",
      "Vercel",
    ],
  },
];

const solvedProblems = [
  {
    title: "Automatización e Integración con IA",
    detail: "Python, IA aplicada y flujos internos para reducir trabajo manual.",
  },
  {
    title: "Crear herramientas internas",
    detail: "APIs, CRMs, CLIs y paneles para equipos comerciales u operativos.",
  },
  {
    title: "Monitoreo de sensores",
    detail: "Ingesta, comunicación y visualización de datos de dispositivos.",
  },
  {
    title: "Desplegar sistemas",
    detail: "Servidores Linux, Vercel y aplicaciones listas para uso interno.",
  },
];
---

<Layout>
  <main
    class="mt-14 mb-14 h-[calc(100vh-7rem)] overflow-y-auto xl:flex xl:overflow-hidden"
  >
    <ul class="flex flex-col gap-1 xl:hidden">
      <p class="text-heading-foreground p-6 text-sm">_experience</p>
      <Sections experiences={experiences} />
    </ul>
    <section
      class="outline-theme-stroke hidden h-full w-72 overflow-y-auto outline xl:block"
    >
      <ul
        class="outline-theme-stroke flex cursor-pointer items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <svg
          width="14"
          height="13"
          viewBox="0 0 14 13"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M13.6667 3.83333V11.8333C13.6667 12.2015 13.3682 12.5 13 12.5H0.999995C0.631808 12.5 0.333328 12.2015 0.333328 11.8333V3.16667H13C13.3682 3.16667 13.6667 3.46515 13.6667 3.83333ZM7.27613 1.83333H0.333328V1.16667C0.333328 0.79848 0.631808 0.5 0.999995 0.5H5.94279L7.27613 1.83333Z"
            fill="#FF637E"></path>
        </svg>

        <span> Empresas </span>
      </ul>
      <ul class="flex flex-col gap-3 py-4">
        {
          experiences.map((experience) => (
            <li class="flex items-center gap-3 px-6">
              <svg
                width="14"
                height="13"
                viewBox="0 0 14 13"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M0.999995 0.5H13C13.3682 0.5 13.6667 0.79848 13.6667 1.16667V11.8333C13.6667 12.2015 13.3682 12.5 13 12.5H0.999995C0.631808 12.5 0.333328 12.2015 0.333328 11.8333V1.16667C0.333328 0.79848 0.631808 0.5 0.999995 0.5ZM3.66666 8.83333V6.16667L5 7.5L6.33333 6.16667V8.83333H7.66666V4.16667H6.33333L5 5.5L3.66666 4.16667H2.33333V8.83333H3.66666ZM11 6.83333V4.16667H9.66666V6.83333H8.33333L10.3333 8.83333L12.3333 6.83333H11Z"
                  fill="#62748E"
                ></path>
              </svg>
              <span class="truncate">{experience.company}</span>
            </li>
          ))
        }
      </ul>
      <ul
        class="outline-theme-stroke flex cursor-pointer items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <svg
          width="14"
          height="13"
          viewBox="0 0 14 13"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M13.6667 3.83333V11.8333C13.6667 12.2015 13.3682 12.5 13 12.5H0.999995C0.631808 12.5 0.333328 12.2015 0.333328 11.8333V3.16667H13C13.3682 3.16667 13.6667 3.46515 13.6667 3.83333ZM7.27613 1.83333H0.333328V1.16667C0.333328 0.79848 0.631808 0.5 0.999995 0.5H5.94279L7.27613 1.83333Z"
            fill="#00D5BE"></path>
        </svg>
        <span> Contacto </span>
      </ul>
      <ul class="flex flex-col gap-2 py-3 pr-3 pl-6">
        <li class="flex items-baseline gap-2">
          <svg
            width="14"
            height="12"
            viewBox="0 0 14 12"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M0.999674 0H12.9997C13.1765 0 13.3461 0.0702379 13.4711 0.195262C13.5961 0.320286 13.6663 0.489856 13.6663 0.666667V11.3333C13.6663 11.5101 13.5961 11.6797 13.4711 11.8047C13.3461 11.9298 13.1765 12 12.9997 12H0.999674C0.822863 12 0.653294 11.9298 0.52827 11.8047C0.403246 11.6797 0.333008 11.5101 0.333008 11.3333V0.666667C0.333008 0.489856 0.403246 0.320286 0.52827 0.195262C0.653294 0.0702379 0.822863 0 0.999674 0V0ZM7.03967 5.78867L2.76501 2.15867L1.90167 3.17467L7.04834 7.54467L12.1023 3.17133L11.2303 2.16267L7.04034 5.78867H7.03967Z"
              fill="#62748E"></path>
          </svg>
          <a href="">denildenilson@gmail.com</a>
        </li>
        <li class="flex items-baseline gap-2">
          <svg
            width="14"
            height="12"
            viewBox="0 0 14 12"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M0.999674 0H12.9997C13.1765 0 13.3461 0.0702379 13.4711 0.195262C13.5961 0.320286 13.6663 0.489856 13.6663 0.666667V11.3333C13.6663 11.5101 13.5961 11.6797 13.4711 11.8047C13.3461 11.9298 13.1765 12 12.9997 12H0.999674C0.822863 12 0.653294 11.9298 0.52827 11.8047C0.403246 11.6797 0.333008 11.5101 0.333008 11.3333V0.666667C0.333008 0.489856 0.403246 0.320286 0.52827 0.195262C0.653294 0.0702379 0.822863 0 0.999674 0V0ZM7.03967 5.78867L2.76501 2.15867L1.90167 3.17467L7.04834 7.54467L12.1023 3.17133L11.2303 2.16267L7.04034 5.78867H7.03967Z"
              fill="#62748E"></path>
          </svg>
          <a href="">jdtrujillos@uni.pe</a>
        </li>
        <li class="flex items-baseline gap-2">
          <svg
            width="12"
            height="12"
            viewBox="0 0 12 12"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 8.94667V11.304C12.0001 11.4728 11.9361 11.6353 11.8211 11.7588C11.706 11.8823 11.5484 11.9575 11.38 11.9693C11.0887 11.9893 10.8507 12 10.6667 12C4.77533 12 0 7.22467 0 1.33333C0 1.14933 0.01 0.911334 0.0306667 0.62C0.0424816 0.451629 0.117721 0.294007 0.241202 0.178939C0.364684 0.0638712 0.527215 -7.62887e-05 0.696 1.71053e-07H3.05333C3.13603 -8.35563e-05 3.2158 0.0305727 3.27715 0.0860136C3.33851 0.141455 3.37706 0.217722 3.38533 0.3C3.40067 0.453334 3.41467 0.575333 3.428 0.668C3.56049 1.59262 3.832 2.49189 4.23333 3.33533C4.29667 3.46867 4.25533 3.628 4.13533 3.71333L2.69667 4.74133C3.5763 6.79097 5.2097 8.42436 7.25933 9.304L8.286 7.868C8.32796 7.80933 8.38919 7.76725 8.459 7.7491C8.52881 7.73095 8.60277 7.73787 8.668 7.76867C9.51135 8.16924 10.4104 8.44008 11.3347 8.572C11.4273 8.58533 11.5493 8.6 11.7013 8.61467C11.7835 8.62309 11.8596 8.66171 11.9149 8.72305C11.9702 8.78439 12.0008 8.86408 12.0007 8.94667H12Z"
              fill="#62748E"></path>
          </svg>

          <a href="">+51 933 156 539</a>
        </li>
      </ul>
    </section>
    <section class="hidden flex-2 flex-col xl:flex">
      <!-- <ul class="flex gap-0">
        {
          experiences.map((experience) => (
            <p
              class="outline-theme-stroke flex h-12 cursor-pointer items-center justify-between gap-8 px-3 outline"
            >
              <span class="inline-block w-56 truncate text-sm">
                {experience.company}
              </span>
              <svg
                class="cursor-pointer"
                width="10"
                height="9"
                viewBox="0 0 10 9"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M4.99999 3.55732L8.29999 0.257324L9.24266 1.19999L5.94266 4.49999L9.24266 7.79999L8.29999 8.74266L4.99999 5.44266L1.69999 8.74266L0.757324 7.79999L4.05732 4.49999L0.757324 1.19999L1.69999 0.257324L4.99999 3.55732Z"
                  fill="#90A1B9"
                ></path>
              </svg>
            </p>
          ))
        }
      </ul> -->
      <div
        class="outline-theme-stroke flex-1 space-y-10 overflow-y-auto px-8 py-8 leading-relaxed outline"
      >
        {
          experiences.map((experience, index) => (
            <article>
              <p class="mb-2 text-sm text-orange-300">
                experiencia_{index + 1}
              </p>
              <h2 class="text-heading-foreground mb-2 text-2xl font-semibold">
                {experience.company}
              </h2>
              <p class="mb-1 text-teal-400">{experience.role}</p>
              <p class="mb-6 text-sm text-slate-500">{experience.period}</p>
              <p class="mb-6">{experience.description}</p>
              <div class="mb-4 flex flex-wrap gap-2">
                {experience.areas.map((area) => (
                  <span class="border-theme-stroke rounded border px-3 py-1 text-sm text-orange-300">
                    {area}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2">
                {experience.stack.map((technology) => (
                  <span class="bg-theme-backdrop border-theme-stroke rounded border px-3 py-1 text-sm text-slate-50">
                    {technology}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </section>
    <section class="hidden flex-1 flex-col xl:flex">
      <ul class="flex gap-0">
        <p
          class="outline-theme-stroke flex h-12 cursor-pointer items-center justify-between gap-8 px-3 pr-9 outline"
        >
          <span class="inline-block truncate text-sm">
            Problemas que resuelvo
          </span>
        </p>
      </ul>
      <div
        class="outline-theme-stroke flex-1 overflow-y-auto px-5 py-5 outline"
      >
        <ol class="space-y-3">
          {
            solvedProblems.map((problem, index) => (
              <li class="group border-theme-stroke bg-theme-backdrop/50 rounded-lg border p-4 transition hover:border-primary-background hover:bg-slate-950">
                <div class="mb-3 flex items-center gap-3">
                  <span class="border-theme-stroke bg-theme-background text-orange-300 grid h-7 w-7 shrink-0 place-content-center rounded border text-xs">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <h3 class="text-heading-foreground text-sm font-semibold leading-snug">
                    {problem.title}
                  </h3>
                </div>
                <p class="text-xs leading-relaxed">{problem.detail}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>
  </main>
</Layout>
