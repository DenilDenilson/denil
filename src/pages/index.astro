---
import BlobGreen from "../components/BlobGreen.astro";
import BlobViolet from "../components/BlobViolet.astro";
import Layout from "../layouts/Layout.astro";

const devicon = (name: string, variant = "original") =>
  `https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/${name}/${name}-${variant}.svg`;

const simpleIcon = (name: string, color = "F8FAFC") =>
  `https://cdn.simpleicons.org/${name}/${color}`;

const skills = [
  { name: "Python", icon: devicon("python") },
  { name: "TypeScript", icon: devicon("typescript") },
  { name: "Node.js", icon: devicon("nodejs") },
  { name: "FastAPI", icon: devicon("fastapi") },
  { name: "Linux", icon: devicon("linux") },
  { name: "PostgreSQL", icon: devicon("postgresql") },
  { name: "SQLite", icon: devicon("sqlite") },
  { name: "SQL", abbr: "SQL" },
  { name: "C", icon: devicon("c") },
  { name: "MQTT", abbr: "MQTT" },
  { name: "Modbus", abbr: "MB" },
  { name: "ESP32", abbr: "ESP" },
  { name: "Git", icon: simpleIcon("git", "F05032") },
];
---

<Layout>
  <main
    class="mt-14 mb-14 grid h-[calc(100vh-7rem)] gap-12 overflow-y-auto overflow-x-hidden py-10 pr-4 pl-6 xl:grid-cols-[minmax(0,760px)_minmax(360px,460px)] xl:items-center xl:gap-20 xl:overflow-hidden xl:py-8 xl:pr-8 xl:pl-[320px]"
  >
    <div class="flex min-w-0 flex-col justify-center gap-12 xl:gap-14">
      <hgroup class="max-w-4xl">
        <h5 class="relative mb-1 text-lg xl:mb-3 xl:text-xl">
          Hola, yo soy
          <div class="absolute -top-32 left-96 hidden xl:block">
            <BlobGreen />
          </div>
        </h5>
        <h1
          class="text-heading-foreground mb-4 text-5xl leading-16 xl:mb-6 xl:text-7xl"
        >
          Denilson Trujillo
        </h1>
        <h3 class="text-xl text-indigo-500 xl:text-3xl">
          &#62 Backend, automatización y sistemas
        </h3>
      </hgroup>

      <section class="max-w-4xl space-y-5 text-base leading-relaxed xl:text-xl">
        <p>
          Construyo APIs, herramientas internas, automatizaciones con IA y
          software conectado a datos, IA y hardware.
        </p>

      </section>

      <section class="max-w-4xl">
        <h5 class="relative mb-4 xl:text-xl">
          &#47&#47 skills
          <div class="absolute -top-48 left-[600px] hidden xl:block">
            <BlobViolet />
          </div>
        </h5>

        <div
          class="skill-carousel border-theme-stroke bg-theme-backdrop/40 relative overflow-hidden rounded-lg border py-4"
        >
          <ul class="skill-track flex w-max items-center gap-3 px-3">
            {
              [...skills, ...skills].map((skill) => (
                <li class="border-theme-stroke bg-theme-background flex h-12 shrink-0 items-center gap-3 rounded-md border px-4 text-sm text-slate-50">
                  {"icon" in skill ? (
                    <img
                      src={skill.icon}
                      alt=""
                      loading="lazy"
                      class="h-7 w-7 shrink-0 object-contain"
                    />
                  ) : (
                    <span class="grid h-7 w-7 shrink-0 place-content-center rounded bg-slate-700 text-[10px] font-semibold text-slate-50">
                      {skill.abbr}
                    </span>
                  )}
                  <span>{skill.name}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </section>
    </div>

    <aside class="flex min-w-0 justify-center xl:justify-end">
      <div class="w-full max-w-full xl:max-w-[460px]">
        <div class="mb-4">
          <h5 class="mb-2 xl:text-xl">&#47&#47 Bullent</h5>
          <p class="text-heading-foreground text-sm">
            Juego propio programado por mí.
            <a
              href="https://github.com/DenilDenilson/bullent"
              target="_blank"
              rel="noreferrer"
              class="text-link-foreground hover:text-primary-background"
            >
              Ver repo
            </a>
          </p>
        </div>
        <iframe
          src="https://bullent.denil.org/?mobile=1"
          title="Bullent"
          width="390"
          height="620"
          loading="lazy"
          class="border-theme-stroke bg-theme-backdrop h-[min(620px,calc(100vh-11rem))] w-full max-w-full rounded-lg border xl:hidden"
        ></iframe>
        <iframe
          src="https://bullent.denil.org/?embed=1"
          title="Bullent"
          width="460"
          height="560"
          loading="lazy"
          class="border-theme-stroke bg-theme-backdrop hidden h-[min(560px,calc(100vh-11rem))] w-full max-w-full rounded-lg border xl:block"
        ></iframe>
      </div>
    </aside>
  </main>
</Layout>

<style>
  .skill-carousel {
    mask-image: linear-gradient(
      90deg,
      transparent,
      black 12%,
      black 88%,
      transparent
    );
  }

  .skill-track {
    animation: scroll-skills 24s linear infinite;
  }

  .skill-carousel:hover .skill-track {
    animation-play-state: paused;
  }

  @keyframes scroll-skills {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-track {
      animation: none;
      flex-wrap: wrap;
      width: auto;
    }
  }
</style>
