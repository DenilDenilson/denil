---
import ChipIcon from "../components/icons/ChipIcon.astro";
import LaptopIcon from "../components/icons/LaptopIcon.astro";
import WebIcon from "../components/icons/WebIcon.astro";
import Filter from "../components/projects/Filter.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import ProjectsContainer from "../components/projects/ProjectsContainer.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="flex-1 pt-14 xl:flex">
    <ul class="flex flex-col gap-1 xl:hidden">
      <p class="text-heading-foreground p-6 text-sm">_proyectos</p>
      <Filter />
    </ul>
    <ProjectsContainer />
    <section class="outline-theme-stroke hidden w-72 outline xl:block">
      <ul
        class="outline-theme-stroke flex cursor-pointer items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <span> Habilidades </span>
      </ul>
      <div class="info max-h-80 overflow-hidden transition-all duration-300">
        <ul class="flex flex-col gap-4 p-6">
          <li class="flex items-center gap-3">
            <input type="checkbox" id="webFilter" class="" />
            <WebIcon />
            <label for="webFilter" class="">Desarr. Web</label>
          </li>
          <li class="flex items-center gap-3">
            <input type="checkbox" id="embeddedFilter" class="" />
            <ChipIcon />
            <label for="embeddedFilter" class="">Sis. Embebidos</label>
          </li>
          <li class="flex items-center gap-3">
            <input type="checkbox" id="softwareFilter" class="" />
            <LaptopIcon />
            <label for="softwareFilter" class="">Desarr. Software</label>
          </li>
        </ul>
      </div>
      <ul
        class="outline-theme-stroke flex cursor-pointer items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <!-- <svg
          width="14"
          height="13"
          viewBox="0 0 14 13"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M13.6667 3.83333V11.8333C13.6667 12.2015 13.3682 12.5 13 12.5H0.999995C0.631808 12.5 0.333328 12.2015 0.333328 11.8333V3.16667H13C13.3682 3.16667 13.6667 3.46515 13.6667 3.83333ZM7.27613 1.83333H0.333328V1.16667C0.333328 0.79848 0.631808 0.5 0.999995 0.5H5.94279L7.27613 1.83333Z"
            fill="#00D5BE"></path>
        </svg> -->
        <span> Estudiando </span>
      </ul>
      <ul class="flex flex-col gap-2 py-3 pr-3 pl-6">
        <li class="flex items-baseline gap-2">
          <svg
            class="h-8 w-8"
            xmlns="http://www.w3.org/2000/svg"
            preserveAspectRatio="xMidYMid"
            viewBox="0 0 256 346"
            ><path
              d="M83 267s-14 8 9 11c27 3 41 2 71-3 0 0 8 5 19 9-67 29-153-2-99-17M74 230s-15 11 8 13c29 3 52 3 92-4 0 0 6 5 15 8-82 24-173 2-115-17"
              fill="#5382A1"></path><path
              d="M144 166c17 19-4 36-4 36s42-22 22-49c-18-26-32-38 44-82 0 0-119 29-62 95"
              fill="#E76F00"></path><path
              d="M233 295s10 8-10 15c-39 12-163 15-197 0-12-5 11-13 18-14l12-2c-14-9-89 19-38 28 138 22 251-10 215-27M89 190s-63 15-22 21c17 2 51 2 83-1 26-2 52-7 52-7l-16 9c-64 16-187 8-151-9 30-14 54-13 54-13M202 253c64-33 34-66 13-61l-7 2s2-3 6-5c41-14 73 43-14 66l2-2"
              fill="#5382A1"></path><path
              d="M162 0s36 36-34 91c-56 45-12 70 0 99-32-30-56-56-40-80 23-35 89-53 74-110"
              fill="#E76F00"></path><path
              d="M95 345c62 4 158-3 160-32 0 0-4 11-51 20-53 10-119 9-158 2 0 0 8 7 49 10"
              fill="#5382A1"></path></svg
          >
          <label for="webFilter" class="ml-3 text-white">Java</label>
        </li>
      </ul>
    </section>
    <section class="hidden flex-1 flex-col xl:flex">
      <ul class="flex gap-0">
        <p
          class="outline-theme-stroke flex h-12 cursor-pointer items-center justify-between gap-8 px-3 outline"
        >
          <span class="inline-block w-48 truncate text-sm"> todos </span>
        </p>
      </ul>
      <div class="outline-theme-stroke flex-1 p-16 leading-loose outline">
        <section class="flex flex-wrap justify-start gap-16 p-6 xl:p-0">
          <ProjectCard />
          <ProjectCard />
          <ProjectCard />
        </section>
      </div>
    </section>
  </main>
</Layout>
