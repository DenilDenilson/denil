---
import ChipIcon from "../components/icons/ChipIcon.astro";
import LaptopIcon from "../components/icons/LaptopIcon.astro";
import WebIcon from "../components/icons/WebIcon.astro";
import Filter from "../components/projects/Filter.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import ProjectsContainer from "../components/projects/ProjectsContainer.astro";
import Layout from "../layouts/Layout.astro";

const devicon = (name: string, variant = "original") =>
  `https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/${name}/${name}-${variant}.svg`;

const simpleIcon = (name: string, color = "F8FAFC") =>
  `https://cdn.simpleicons.org/${name}/${color}`;

const projects = [
  {
    title: "mmj-web",
    description: "Web oficial de MMJ Smart Electronics.",
    stack: ["Astro", "TypeScript", "JavaScript"],
    categories: ["web"],
    codeUrl: "https://github.com/DenilDenilson/mmj-web",
    previewUrl: "https://www.smartelectronics.com.pe/",
    image: "https://opengraph.githubassets.com/1/DenilDenilson/mmj-web",
  },
  {
    title: "rat-cli",
    description:
      "Herramienta CLI escrita en C que genera una vista lineal de un proyecto para copiar y compartir fácilmente con LLMs como ChatGPT.",
    stack: ["C", "Makefile", "CLI", "MIT"],
    categories: ["software"],
    codeUrl: "https://github.com/DenilDenilson/rat-cli",
    image: "https://opengraph.githubassets.com/1/DenilDenilson/rat-cli",
  },
  {
    title: "save-your-tabs",
    description:
      "Extensión de Chrome para guardar pestañas, generar un link y reabrirlas en otro navegador con un click.",
    stack: ["HTML", "JavaScript", "CSS", "Chrome Extension"],
    categories: ["web", "software"],
    codeUrl: "https://github.com/DenilDenilson/save-your-tabs",
    previewUrl: "https://syt.denil.org/",
    image:
      "https://opengraph.githubassets.com/1/DenilDenilson/save-your-tabs",
  },
  {
    title: "demi-software",
    description:
      "Backend de Demi, un asistente físico e inteligente diseñado para capturar, procesar y actuar sobre información en tiempo real a partir de audio.",
    stack: ["Python", "Backend", "Audio", "IA"],
    categories: ["software", "embedded"],
    codeUrl: "https://github.com/DenilDenilson/demi-software",
    image:
      "https://opengraph.githubassets.com/1/DenilDenilson/demi-software",
  },
  {
    title: "lima-revelada",
    description:
      "Plataforma web interactiva que convierte un paseo por Lima en una experiencia de misterio, curiosidades y relatos ocultos sobre un mapa minimalista.",
    stack: ["Astro", "TypeScript", "CSS", "JavaScript"],
    categories: ["web"],
    codeUrl: "https://github.com/DenilDenilson/lima-revelada",
    previewUrl: "https://lima-revelada.vercel.app",
    image:
      "https://opengraph.githubassets.com/1/DenilDenilson/lima-revelada",
  },
];

const skillGroups = [
  {
    title: "web full stack",
    skills: [
      { name: "HTML", icon: devicon("html5") },
      { name: "CSS", icon: devicon("css3") },
      { name: "TailwindCSS", icon: devicon("tailwindcss") },
      { name: "JavaScript", icon: devicon("javascript") },
      { name: "TypeScript", icon: devicon("typescript") },
      { name: "React", icon: devicon("react") },
      { name: "Astro", icon: simpleIcon("astro", "FF5D01") },
      { name: "Next JS", icon: simpleIcon("nextdotjs") },
      { name: "Python", icon: devicon("python") },
      { name: "Flask", icon: simpleIcon("flask") },
      { name: "FastAPI", icon: devicon("fastapi") },
      { name: "Java", icon: devicon("java") },
      { name: "Spring Boot", icon: devicon("spring") },
      { name: "Git & GitHub", icon: simpleIcon("github") },
    ],
  },
  {
    title: "applications",
    skills: [
      { name: "Java - Spring", icon: devicon("spring") },
      { name: "LabVIEW", abbr: "LV" },
      { name: "Linux", icon: devicon("linux") },
    ],
  },
  {
    title: "data",
    skills: [
      { name: "SQL", abbr: "SQL" },
      { name: "PostgreSQL", icon: devicon("postgresql") },
      { name: "SQLite", icon: devicon("sqlite") },
      { name: "Python - pandas", icon: devicon("pandas") },
    ],
  },
  {
    title: "extra skills",
    skills: [
      { name: "Inglés", abbr: "EN" },
      { name: "LaTeX", icon: simpleIcon("latex", "008080") },
    ],
  },
];
---

<Layout>
  <main class="flex-1 pt-14 xl:flex">
    <ul class="flex flex-col gap-1 xl:hidden">
      <p class="text-heading-foreground p-6 text-sm">_proyectos</p>
      <Filter />
    </ul>
    <ProjectsContainer projects={projects} />
    <section
      class="outline-theme-stroke hidden max-h-[calc(100vh-7rem)] w-72 overflow-y-auto outline xl:block"
    >
      <ul
        class="outline-theme-stroke flex cursor-pointer items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <span> Filtros </span>
      </ul>
      <div class="info max-h-80 overflow-hidden transition-all duration-300">
        <ul class="flex flex-col gap-4 p-6">
          <li class="flex items-center gap-3">
            <input
              type="checkbox"
              id="desktopWebFilter"
              value="web"
              data-project-filter
              class=""
            />
            <WebIcon />
            <label for="desktopWebFilter" class="">Desarr. Web</label>
          </li>
          <li class="flex items-center gap-3">
            <input
              type="checkbox"
              id="desktopEmbeddedFilter"
              value="embedded"
              data-project-filter
              class=""
            />
            <ChipIcon />
            <label for="desktopEmbeddedFilter" class="">Sis. Embebidos</label>
          </li>
          <li class="flex items-center gap-3">
            <input
              type="checkbox"
              id="desktopSoftwareFilter"
              value="software"
              data-project-filter
              class=""
            />
            <LaptopIcon />
            <label for="desktopSoftwareFilter" class="">Desarr. Software</label>
          </li>
        </ul>
      </div>
      <ul
        class="outline-theme-stroke flex cursor-pointer items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <span> Skills </span>
      </ul>
      <div>
        {
          skillGroups.map((group) => (
            <section class="border-theme-stroke border-b px-6 py-4">
              <h3 class="mb-3 text-xs uppercase text-slate-500">
                {group.title}
              </h3>
              <ul class="flex flex-col gap-3">
                {group.skills.map((skill) => (
                  <li class="flex items-center gap-3">
                    {"icon" in skill ? (
                      <img
                        src={skill.icon}
                        alt=""
                        loading="lazy"
                        class="h-7 w-7 shrink-0 object-contain"
                      />
                    ) : (
                      <span class="grid h-7 w-7 shrink-0 place-content-center rounded bg-slate-700 text-[10px] font-semibold text-slate-50">
                        {skill.abbr}
                      </span>
                    )}
                    <span class="min-w-0 text-sm text-slate-50">
                      {skill.name}
                    </span>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
      <ul
        class="outline-theme-stroke flex cursor-pointer items-center gap-3 px-6 py-3 text-slate-50 outline"
      >
        <!-- <svg
          width="14"
          height="13"
          viewBox="0 0 14 13"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M13.6667 3.83333V11.8333C13.6667 12.2015 13.3682 12.5 13 12.5H0.999995C0.631808 12.5 0.333328 12.2015 0.333328 11.8333V3.16667H13C13.3682 3.16667 13.6667 3.46515 13.6667 3.83333ZM7.27613 1.83333H0.333328V1.16667C0.333328 0.79848 0.631808 0.5 0.999995 0.5H5.94279L7.27613 1.83333Z"
            fill="#00D5BE"></path>
        </svg> -->
        <span> Estudiando </span>
      </ul>
      <ul class="flex flex-col gap-2 py-3 pr-3 pl-6">
        <li class="flex items-baseline gap-2">
          <svg
            class="h-8 w-8"
            xmlns="http://www.w3.org/2000/svg"
            preserveAspectRatio="xMidYMid"
            viewBox="0 0 256 346"
            ><path
              d="M83 267s-14 8 9 11c27 3 41 2 71-3 0 0 8 5 19 9-67 29-153-2-99-17M74 230s-15 11 8 13c29 3 52 3 92-4 0 0 6 5 15 8-82 24-173 2-115-17"
              fill="#5382A1"></path><path
              d="M144 166c17 19-4 36-4 36s42-22 22-49c-18-26-32-38 44-82 0 0-119 29-62 95"
              fill="#E76F00"></path><path
              d="M233 295s10 8-10 15c-39 12-163 15-197 0-12-5 11-13 18-14l12-2c-14-9-89 19-38 28 138 22 251-10 215-27M89 190s-63 15-22 21c17 2 51 2 83-1 26-2 52-7 52-7l-16 9c-64 16-187 8-151-9 30-14 54-13 54-13M202 253c64-33 34-66 13-61l-7 2s2-3 6-5c41-14 73 43-14 66l2-2"
              fill="#5382A1"></path><path
              d="M162 0s36 36-34 91c-56 45-12 70 0 99-32-30-56-56-40-80 23-35 89-53 74-110"
              fill="#E76F00"></path><path
              d="M95 345c62 4 158-3 160-32 0 0-4 11-51 20-53 10-119 9-158 2 0 0 8 7 49 10"
              fill="#5382A1"></path></svg
          >
          <label for="webFilter" class="ml-3 text-white">Java</label>
        </li>
      </ul>
    </section>
    <section class="hidden flex-1 flex-col xl:flex">
      <ul class="flex gap-0">
        <p
          class="outline-theme-stroke flex h-12 cursor-pointer items-center justify-between gap-8 px-3 outline"
        >
          <span class="inline-block w-48 truncate text-sm">
            todos (<span data-project-count>{projects.length}</span>)
          </span>
        </p>
      </ul>
      <div class="outline-theme-stroke flex-1 overflow-y-auto p-8 outline">
        <section class="flex max-w-5xl flex-col gap-6">
          {projects.map((project) => <ProjectCard project={project} />)}
        </section>
        <p
          data-project-empty
          class="text-heading-foreground hidden max-w-5xl py-16 text-center"
        >
          No hay proyectos para los filtros seleccionados.
        </p>
      </div>
    </section>
  </main>
</Layout>

<script>
  const projectFilters = document.querySelectorAll("[data-project-filter]");
  const projectCards = document.querySelectorAll("[data-project-card]");
  const projectCounters = document.querySelectorAll("[data-project-count]");
  const emptyStates = document.querySelectorAll("[data-project-empty]");

  function applyProjectFilters() {
    const activeFilters = Array.from(projectFilters)
      .filter((filter) => filter.checked)
      .map((filter) => filter.value);

    const visibleProjects = new Set();

    projectCards.forEach((card) => {
      const categories = (card.dataset.categories || "").split(" ");
      const isVisible =
        activeFilters.length === 0 ||
        activeFilters.some((filter) => categories.includes(filter));

      card.style.display = isVisible ? "" : "none";
      if (isVisible && card.dataset.projectId) {
        visibleProjects.add(card.dataset.projectId);
      }
    });

    projectCounters.forEach((counter) => {
      counter.textContent = String(visibleProjects.size);
    });

    emptyStates.forEach((emptyState) => {
      emptyState.classList.toggle("hidden", visibleProjects.size !== 0);
    });
  }

  projectFilters.forEach((filter) => {
    filter.addEventListener("change", () => {
      projectFilters.forEach((otherFilter) => {
        if (otherFilter.value === filter.value) {
          otherFilter.checked = filter.checked;
        }
      });

      applyProjectFilters();
    });
  });

  applyProjectFilters();
</script>
